# Environment Configuration for diablito-deploy

# Polling interval in milliseconds (default: 5 minutes)
# Use shorter intervals for testing: 10000 (10 seconds)
POLL_INTERVAL=300000

# Root directory where to scan for repositories
# All subdirectories will be scanned for .git folders
# Hidden folders (starting with ".") are filtered out
REPOS_ROOT=~/projects

# Log level: debug, info, warn, error
LOG_LEVEL=info
