{
  "name": "devops-custom",
  "version": "0.1.2",
  "description": "Auto-update daemon para proyectos Node con Git + PM2",
  "author": "diablito",
  "license": "ISC",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "bin": {
    "devops-custom": "dist/cjs/cli.js"
  },
  "scripts": {
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build": "yarn test && rm -rf dist/* && yarn build:cjs && yarn build:esm && typedoc",
    "dev": "ts-node src/cli.ts",
    "dev:watch": "ts-node --watch src/cli.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./jest.config.e2e.ts --forceExit",
    "release": "./release.sh",
    "version-bump": "node update-version.js"
  },
  "keywords": [
    "git",
    "pm2",
    "autodeploy",
    "autoupdate",
    "daemon",
    "typescript",
    "devops"
  ],
  "dependencies": {
    "dotenv": "^16.3.1",
    "pino": "^8.17.0",
    "pm2": "^5.3.0",
    "simple-git": "^3.20.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typedoc": "^0.25.3",
    "typescript": "^5.3.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joneldiablo/devops-custom.git"
  },
  "directories": {
    "ts": "src",
    "esm": "dist/esm",
    "cjs": "dist/cjs"
  }
}