{
  "name": "devops-custom",
  "version": "0.1.7",
  "description": "Auto-update daemon para proyectos Node con Git + PM2",
  "author": "diablito",
  "license": "ISC",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "bin": {
    "devops-custom": "dist/cjs/cli.js"
  },
  "scripts": {
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build": "yarn test && rm -rf dist/* && yarn build:cjs && yarn build:esm && typedoc",
    "dev": "ts-node src/cli.ts",
    "dev:watch": "ts-node --watch src/cli.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./jest.config.e2e.ts --forceExit",
    "release": "./release.sh",
    "version-bump": "node update-version.js"
  },
  "keywords": [
    "git",
    "pm2",
    "autodeploy",
    "autoupdate",
    "daemon",
    "typescript",
    "devops"
  ],
  "dependencies": {
    "dotenv": "^16.3.1",
    "pino": "^8.17.0",
    "pm2": "^5.3.0",
    "simple-git": "^3.20.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.10.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typedoc": "^0.25.3",
    "typescript": "^5.3.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joneldiablo/devops-custom.git"
  },
  "directories": {
    "ts": "src",
    "esm": "dist/esm",
    "cjs": "dist/cjs"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts",
      "source": "./src/index.ts"
    },
    "./cli/commands/scan": {
      "import": "./dist/esm/cli/commands/scan.js",
      "require": "./dist/cjs/cli/commands/scan.js",
      "types": "./dist/types/cli/commands/scan.d.ts",
      "source": "./src/cli/commands/scan.ts"
    },
    "./cli/commands/start": {
      "import": "./dist/esm/cli/commands/start.js",
      "require": "./dist/cjs/cli/commands/start.js",
      "types": "./dist/types/cli/commands/start.d.ts",
      "source": "./src/cli/commands/start.ts"
    },
    "./cli/commands/status": {
      "import": "./dist/esm/cli/commands/status.js",
      "require": "./dist/cjs/cli/commands/status.js",
      "types": "./dist/types/cli/commands/status.d.ts",
      "source": "./src/cli/commands/status.ts"
    },
    "./cli": {
      "import": "./dist/esm/cli.js",
      "require": "./dist/cjs/cli.js",
      "types": "./dist/types/cli.d.ts",
      "source": "./src/cli.ts"
    },
    "./core/poller": {
      "import": "./dist/esm/core/poller.js",
      "require": "./dist/cjs/core/poller.js",
      "types": "./dist/types/core/poller.d.ts",
      "source": "./src/core/poller.ts"
    },
    "./core/scanner": {
      "import": "./dist/esm/core/scanner.js",
      "require": "./dist/cjs/core/scanner.js",
      "types": "./dist/types/core/scanner.d.ts",
      "source": "./src/core/scanner.ts"
    },
    "./core/worker": {
      "import": "./dist/esm/core/worker.js",
      "require": "./dist/cjs/core/worker.js",
      "types": "./dist/types/core/worker.d.ts",
      "source": "./src/core/worker.ts"
    },
    "./index": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts",
      "source": "./src/index.ts"
    },
    "./types": {
      "import": "./dist/esm/types.js",
      "require": "./dist/cjs/types.js",
      "types": "./dist/types/types.d.ts",
      "source": "./src/types.ts"
    },
    "./utils/git": {
      "import": "./dist/esm/utils/git.js",
      "require": "./dist/cjs/utils/git.js",
      "types": "./dist/types/utils/git.d.ts",
      "source": "./src/utils/git.ts"
    },
    "./utils/lock": {
      "import": "./dist/esm/utils/lock.js",
      "require": "./dist/cjs/utils/lock.js",
      "types": "./dist/types/utils/lock.d.ts",
      "source": "./src/utils/lock.ts"
    },
    "./utils/logger": {
      "import": "./dist/esm/utils/logger.js",
      "require": "./dist/cjs/utils/logger.js",
      "types": "./dist/types/utils/logger.d.ts",
      "source": "./src/utils/logger.ts"
    },
    "./utils/pm2": {
      "import": "./dist/esm/utils/pm2.js",
      "require": "./dist/cjs/utils/pm2.js",
      "types": "./dist/types/utils/pm2.d.ts",
      "source": "./src/utils/pm2.ts"
    }
  }
}